PORT=8800
WEB_PORT=5173
VITE_API_BASE=http://127.0.0.1:8800/api
# Local-only browser demo mode. Set false for hosted/production builds.
VITE_LOCAL_DEMO=true
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-4b
CLOUDFLARE_WORKER_URL=
ULTIDA_WORKER_SHARED_SECRET=
# Must be a vision model; the text-only Llama 3 8B model cannot inspect plans.
CLOUDFLARE_VISION_MODEL=@cf/meta/llama-3.2-11b-vision-instruct
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
PEDRA_API_KEY=
AI_HOME_DESIGN_API_KEY=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
# Optional override when plan analysis and image generation use different Gemini projects.
GEMINI_VISION_API_KEY=
# Nano Banana 2 image generation. Keep this server-only; it is never a VITE_ variable.
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
PLAN_ANALYZER_MODE=
# Plan files go to one provider at a time. Gemini is the default primary; OpenAI and
# Cloudflare are only attempted after a provider failure. Set true only when a second
# provider may receive the same private plan for verification.
PLAN_ANALYZER_PRIMARY=openai
PLAN_ANALYZER_VERIFY=false
PLAN_ANALYZER_TIMEOUT_MS=60000

# Optional local ComfyUI visual provider. The workflow JSON should use
# {{prompt}}, {{style}}, and {{sceneVersionId}} placeholders where needed.
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_JSON=
PRIMARY_IMAGE_PROVIDER=unavailable
